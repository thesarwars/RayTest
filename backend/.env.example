# ─── App ───
APP_NAME=inventory-reservation-system
DEBUG=true

# ─── PostgreSQL ───
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory_secret
POSTGRES_DB=inventory_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://inventory:inventory_secret@postgres:5432/inventory_db

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── JWT ───
JWT_SECRET_KEY=CHANGE-ME-TO-A-REAL-SECRET-IN-PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Reservation ───
RESERVATION_TTL_SECONDS=300
